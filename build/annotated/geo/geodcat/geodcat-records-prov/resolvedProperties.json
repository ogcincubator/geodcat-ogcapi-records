{"defs":{"0":[{"path":["alternate"],"description":"The name of the language in another well-understood language,\nusually English.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.language"]},{"path":["code"],"description":"The language tag as per RFC-5646.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.language"]},{"path":["dir"],"description":"The direction for text in this language. The default, `ltr`\n(left-to-right), represents the most common situation.\nHowever, care should be taken to set the value of `dir`\nappropriately if the language direction is not `ltr`.\nOther values supported are `rtl` (right-to-left), `ttb`\n(top-to-bottom), and `btt` (bottom-to-top).","schema_type":"string","enum":["ltr","rtl","ttb","btt"],"sources":["bblocks://ogc.api.records.v1.schemas.language"]},{"path":["name"],"description":"The untranslated name of the language.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.language"]}],"1":[{"path":["anchor"],"schema_type":"string","sources":["bblocks://ogc.ogc-utils.json-link"]},{"path":["created"],"id":"http://purl.org/dc/terms/created","description":"Date of creation of the resource pointed to by the link.","schema_type":"string","format":"date-time","sources":["bblocks://ogc.api.records.v1.schemas.linkBase"],"effectiveId":"http://purl.org/dc/terms/created"},{"path":["href"],"id":"http://www.w3.org/ns/oa#hasTarget","jsonld_type":"@id","required":true,"schema_type":"string","format":"uri-reference","sources":["bblocks://ogc.ogc-utils.json-link","bblocks://ogc.api.records.v1.schemas.link"],"effectiveId":"http://www.w3.org/ns/oa#hasTarget"},{"path":["hreflang"],"id":"http://purl.org/dc/terms/language","description":"A hint indicating what the language of the result of dereferencing the link should be.","schema_type":"string","sources":["bblocks://ogc.ogc-utils.json-link","bblocks://ogc.api.records.v1.schemas.linkBase"],"effectiveId":"http://purl.or