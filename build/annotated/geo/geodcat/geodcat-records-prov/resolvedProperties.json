["bblocks://ogc.geo.common.data_types.geojson","bblocks://ogc.api.records.v1.schemas.recordGeoJSON","bblocks://ogc.ogc-utils.prov-entity"],"effectiveId":"@id"},{"path":["properties"],"id":"@nest","required":true,"schema_type":"object","sources":["bblocks://ogc.geo.common.data_types.geojson","bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"@nest"},{"path":["geometry"],"id":"https://purl.org/geojson/vocab#geometry","required":true,"sources":["bblocks://ogc.geo.common.data_types.geojson","bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://purl.org/geojson/vocab#geometry"},{"path":["geometry","_oneOf"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"oneOf"},{"path":["geometry","_oneOf","1"],"title":"GeoJSON Point","sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"branch"},{"path":["geometry","_oneOf","1","type"],"id":"@type","required":true,"schema_type":"string","enum":["Point"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["geometry","_oneOf","1","coordinates"],"id":"https://purl.org/geojson/vocab#coordinates","required":true,"schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"https://purl.org/geojson/vocab#coordinates"},{"path":["geometry","_oneOf","1","bbox"],"id":"https://purl.org/geojson/vocab#bbox","schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"https://purl.org/geojson/vocab#bbox"},{"path":["geometry","_oneOf","2"],"title":"GeoJSON LineString","sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"branch"},{"path":["geometry","_oneOf","2","type"],"id":"@type","required":true,"schema_type":"string","enum":["LineString"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["geometry","_oneOf","2","coordinates"],"id":"https://purl.org/geojson/vocab#coordinates","required":true,"schema_type":"array","