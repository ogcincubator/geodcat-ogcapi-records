uired":true,"schema_type":"string","enum":["MultiLineString"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["geometry","_oneOf","7","geometries","_oneOf","5"],"title":"GeoJSON MultiPolygon","sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"branch"},{"path":["geometry","_oneOf","7","geometries","_oneOf","5","type"],"id":"@type","required":true,"schema_type":"string","enum":["MultiPolygon"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["geometry","_oneOf","7","bbox"],"id":"https://purl.org/geojson/vocab#bbox","schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"https://purl.org/geojson/vocab#bbox"},{"path":["bbox"],"id":"https://purl.org/geojson/vocab#bbox","schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson","bblocks://ogc.geo.features.feature"],"effectiveId":"https://purl.org/geojson/vocab#bbox"},{"path":["links"],"id":"http://www.w3.org/2000/01/rdf-schema#seeAlso","required":true,"schema_type":"array","sources":["bblocks://ogc.geo.features.feature","bblocks://ogc.api.records.v1.schemas.recordGeoJSON","bblocks://ogc.ogc-utils.prov-entity"],"ref":"1","effectiveId":"http://www.w3.org/2000/01/rdf-schema#seeAlso"},{"path":["conformsTo"],"id":"http://purl.org/dc/terms/conformsTo","jsonld_type":"@id","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://purl.org/dc/terms/conformsTo"},{"path":["time"],"id":"http://purl.org/dc/terms/temporal","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://purl.org/dc/terms/temporal"},{"path":["properties","created"],"id":"http://purl.org/dc/terms/created","description":"Date of creation of this record.","schema_type":"string","format":"date-time","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://purl.org/dc/terms/created"},{"path":["properties","updated"],"id":"http://purl.org/dc/terms/modified","description":"The most recent date on which the record was changed.","schema_type":"string","format":"date-time","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://purl.org/dc/terms/modified"},{"path":["properties","type"],"description":"The nature or genre of the resource. The value should be a code, convenient for filtering records. Where available, a link to the canonical URI of the record type resource will be added to the 'links' property.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"]},{"path":["properties","title"],"id":"http://purl.org/dc/terms/title","description":"A human-readable name given to the resource.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://purl.org/dc/terms/title"},{"path":["properties","description"],"id":"http://purl.org/dc/terms/description","description":"A free-text account of the resource.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://purl.org/dc/terms/description"},{"path":["properties","keywords"],"id":"http://www.w3.org/ns/dcat#keyword","description":"The topic or topics of the resource. Typically represented using free-form keywords, tags, key phrases, or classification codes.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://www.w3.org/ns/dcat#keyword"},{"path":["properties","language"],"id":"https://www.opengis.net/def/ogc-api/records/language","description":"The language used for textual values in this record representation.","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"ref":"0","effectiveId":"https://www.opengis.net/def/ogc-api/records/language"},{"path":["properties","languages"],"id":"https://www.opengis.net/def/ogc-api/records/languages","description":"This list of languages in which this record is available.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"ref":"0","effectiveId":"https://www.opengis.net/def/ogc-api/records/languages"},{"path":["properties","resourceLanguages"],"id":"https://www.opengis.net/def/ogc-api/records/resourceLanguages","description":"The list of languages in which the resource described by this record is available.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"ref":"0","effectiveId":"https://www.opengis.net/def/ogc-api/records/resourceLanguages"},{"path":["properties","externalIds"],"id":"https://www.opengis.net/def/ogc-api/records/scopedIdentifier","description":"An identifier for the resource assigned by an external (to the catalog) entity.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/scopedIdentifier"},{"path":["properties","externalIds","scheme"],"id":"https://www.opengis.net/def/ogc-api/records/scheme","description":"A reference to an authority or identifier for a knowledge organization system from which the external identifier was obtained. It is recommended that the identifier be a resolvable URI.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/scheme"},{"path":["properties","externalIds","value"],"id":"https://www.opengis.net/def/ogc-api/records/id","description":"The value of the identifier.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/id"},{"path":["properties","themes"],"id":"https://www.opengis.net/def/ogc-api/records/themes","description":"A knowledge organization system used to classify the resource.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/themes"},{"path":["properties","themes","concepts"],"id":"https://w3id.org/ogc/stac/themes/concepts","description":"One or more entity/concept identifiers from this knowledge\nsystem. it is recommended that a resolvable URI be used for\neach entity/concept identifier.","required":true,"schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"https://w3id.org/ogc/stac/themes/concepts"},{"path":["properties","themes","concepts","id"],"id":"https://w3id.org/ogc/stac/themes/id","description":"An identifier for the concept.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"https://w3id.org/ogc/stac/themes/id"},{"path":["properties","themes","concepts","title"],"id":"http://purl.org/dc/terms/title","description":"A human readable title for the concept.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"http://purl.org/dc/terms/title"},{"path":["properties","themes","concepts","description"],"id":"http://purl.org/dc/terms/description","description":"A human readable description for the concept.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"http://purl.org/dc/terms/description"},{"path":["properties","themes","concepts","url"],"id":"@id","description":"A URI providing further description of the concept.","schema_type":"string","format":"uri","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"@id"},{"path":["properties","themes","scheme"],"id":"https://w3id.org/ogc/stac/themes/scheme","description":"An identifier for the knowledge organization system used\nto classify the resource.  It is recommended that the\nidentifier be a resolvable URI.  The list of schemes used\nin a searchable catalog can be determined by inspecting\nthe server's OpenAPI document or, if the server implements\nCQL2, by exposing a queryable (e.g. named `scheme`) and\nenumerating the list of schemes in the queryable's schema\ndefinition.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"https://w3id.org/ogc/stac/themes/scheme"},{"path":["properties","formats"],"id":"https://www.opengis.net/def/ogc-api/records/format","jsonld_type":"@id","description":"A list of available distributions of the resource.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/format"},{"path":["properties","formats","name"],"id":"https://www.opengis.net/def/ogc-api/records/name","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/name"},{"path":["properties","formats","mediaType"],"id":"https://www.opengis.net/def/ogc-api/records/mediaType","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/mediaType"},{"path":["properties","contacts"],"id":"http://www.w3.org/ns/dcat#contactPoint","jsonld_type":"@id","description":"A list of contacts qualified by their role(s) in association to the record or the resource described by the record.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://www.w3.org/ns/dcat#contactPoint"},{"path":["properties","contacts","identifier"],"description":"A value uniquely identifying a contact.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","name"],"description":"The name of the responsible person.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","position"],"description":"The name of the role or position of the responsible person taken from the organization's formal organizational hierarchy or chart.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","organization"],"description":"Organization/affiliation of the contact.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","logo"],"description":"Graphic identifying a contact. The link relation should be `icon` and the media type should be an image media type.","sources":["bblocks://ogc.api.records.v1.schemas.contact"],"ref":"1"},{"path":["properties","contacts","logo","rel"],"required":true,"enum":["icon"],"sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","phones"],"description":"Telephone numbers at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","phones","value"],"description":"The value is the phone number itself.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","phones","roles"],"description":"The type of phone number (e.g. home, work, fax, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","emails"],"description":"Email addresses at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","emails","value"],"description":"The value is the email number itself.","required":true,"schema_type":"string","format":"email","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","emails","roles"],"description":"The type of email (e.g. home, work, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses"],"description":"Physical location at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","deliveryPoint"],"description":"Address lines for the location.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","city"],"description":"City for the location.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","administrativeArea"],"description":"State or province of the location.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","postalCode"],"description":"ZIP or other postal code.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","country"],"description":"Country of the physical address.  ISO 3166-1 is recommended.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","roles"],"description":"The type of address (e.g. office, home, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","links"],"description":"On-line information about the contact.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"],"ref":"1"},{"path":["properties","contacts","hoursOfService"],"description":"Time period when the contact can be contacted.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","contactInstructions"],"description":"Supplemental instructions on how or when to contact the\nresponsible party.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","roles"],"description":"The set of named duties, job functions and/or permissions associated with this contact. (e.g. developer, administrator, etc.).","sources":["bblocks://ogc.api.records.v1.