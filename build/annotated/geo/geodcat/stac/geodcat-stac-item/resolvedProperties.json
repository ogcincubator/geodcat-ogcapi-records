":["properties","contacts"],"id":"http://www.w3.org/ns/dcat#contactPoint","jsonld_type":"@id","description":"A list of contacts qualified by their role(s) in association to the record or the resource described by the record.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"http://www.w3.org/ns/dcat#contactPoint"},{"path":["properties","contacts","identifier"],"description":"A value uniquely identifying a contact.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","name"],"description":"The name of the responsible person.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","position"],"description":"The name of the role or position of the responsible person taken from the organization's formal organizational hierarchy or chart.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","organization"],"description":"Organization/affiliation of the contact.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","logo"],"description":"Graphic identifying a contact. The link relation should be `icon` and the media type should be an image media type.","sources":["bblocks://ogc.api.records.v1.schemas.contact"],"ref":"1"},{"path":["properties","contacts","logo","rel"],"required":true,"enum":["icon"],"sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","phones"],"description":"Telephone numbers at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","phones","value"],"description":"The value is the phone number itself.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","phones","roles"],"description":"The type of phone number (e.g. home, work, fax, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","emails"],"description":"Email addresses at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","emails","value"],"description":"The value is the email number itself.","required":true,"schema_type":"string","format":"email","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","emails","roles"],"description":"The type of email (e.g. home, work, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses"],"description":"Physical location at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","deliveryPoint"],"description":"Address lines for the location.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","city"],"description":"City for the location.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","administrativeArea"],"description":"State or province of the location.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","postalCode"],"description":"ZIP or other postal code.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","country"],"description":"Country of the physical address.  ISO 3166-1 is recommended.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["properties","contacts","addresses","roles"],"description":"The type of address (e.g. office, home, e